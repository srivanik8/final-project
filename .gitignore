# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Datasets: never commit the large raw NTLNP data, but DO commit the small
# ready-to-run real-image dataset so the repo works straight after `git clone`.
data/*
!data/.gitkeep
!data/real_animals/
data/ntlnp/
data/ntlnp_raw/
CIFAR-10-images/

# Training artifacts
*.pt
*.pth
checkpoints/

# Results are regenerated by the scripts; keep the folder, ignore heavy outputs
results/*
!results/.gitkeep
!results/README.md

# OS / editor
.DS_Store
.idea/
.vscode/
