# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Datasets: never commit the large raw NTLNP data, but DO commit the small
# ready-to-run real infrared night-vision dataset so the repo works after clone.
data/*
!data/.gitkeep
!data/night_wildlife/
data/ntlnp/
data/ntlnp_raw/
CIFAR-10-images/
.cct_cache/

# Training artifacts
*.pt
*.pth
checkpoints/

# Results are regenerated by the scripts; keep the folder, ignore heavy outputs
results/*
!results/.gitkeep
!results/README.md

# OS / editor
.DS_Store
.idea/
.vscode/
