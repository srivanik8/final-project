{
  "data_dir": "data/night_wildlife",
  "image_size": 224,
  "val_fraction": 0.15,
  "test_fraction": 0.15,
  "split_by": "location",
  "manifest_name": "manifest.csv",
  "crop_to_bbox": true,
  "grayscale_to_rgb": true,
  "num_workers": 2,
  "backbone": "resnet18",
  "pretrained": true,
  "freeze_until": "layer2",
  "epochs": 16,
  "batch_size": 32,
  "learning_rate": 0.0003,
  "weight_decay": 0.0001,
  "label_smoothing": 0.05,
  "early_stop_patience": 5,
  "seed": 42,
  "deterministic": true,
  "device": "cpu",
  "output_dir": "results/demo",
  "checkpoint_name": "best_model.pt",
  "experiment_name": "night_wildlife_resnet18"
}